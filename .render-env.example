APP_NAME=Streamit
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-render-service.onrender.com

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=<from-render-mysql>
DB_PORT=3306
DB_DATABASE=<from-render-mysql>
DB_USERNAME=<from-render-mysql>
DB_PASSWORD=<from-render-mysql>

CACHE_DRIVER=file
SESSION_DRIVER=database
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public

MEDIA_DISK=public
ACTIVE_STORAGE=local

MIX_ASSET_URL=${APP_URL}
MIX_APP_URL=${APP_URL}
